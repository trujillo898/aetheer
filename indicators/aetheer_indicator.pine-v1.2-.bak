//@version=5
// ============================================================================
// AETHEER INDICATOR v1.2 - Data feed para agentes MCP
// PROPÓSITO: Exportar datos estructurados vía JSON para consumo programático
// NO USAR como indicador visual de trading - la tabla es solo para debug
// ============================================================================
indicator("Aetheer", overlay=true, max_labels_count=500, max_lines_count=500, max_tables_count=1)

// ============================================================================
// CONFIGURACIÓN
// ============================================================================
// Grupo: Volatilidad
grp_vol = "Volatilidad / Liquidez"
atr_len     = input.int(14, "ATR Length", minval=1, group=grp_vol)
atr_sma_len = input.int(20, "ATR SMA Length", minval=1, group=grp_vol)
vol_len     = input.int(20, "Volume SMA Length", minval=1, group=grp_vol)

// Grupo: Estructura
grp_struct = "Estructura de Precio"
ema20_len  = input.int(20, "EMA 20", minval=1, group=grp_struct)
ema50_len  = input.int(50, "EMA 50", minval=1, group=grp_struct)
ema200_len = input.int(200, "EMA 200", minval=1, group=grp_struct)
rsi_len    = input.int(14, "RSI Length", minval=1, group=grp_struct)
bb_len     = input.int(20, "Bollinger Length", minval=1, group=grp_struct)
bb_mult    = input.float(2.0, "Bollinger Mult", minval=0.1, step=0.1, group=grp_struct)

// Grupo: Sesiones (UTC)
grp_sess = "Sesiones (UTC)"
asia_start   = input.int(0, "Asia Start Hour", minval=0, maxval=23, group=grp_sess)
asia_end     = input.int(8, "Asia End Hour", minval=0, maxval=23, group=grp_sess)
london_start = input.int(8, "London Start Hour", minval=0, maxval=23, group=grp_sess)
london_end   = input.int(16, "London End Hour", minval=0, maxval=23, group=grp_sess)
ny_start     = input.int(13, "NY Start Hour", minval=0, maxval=23, group=grp_sess)
ny_end       = input.int(21, "NY End Hour", minval=0, maxval=23, group=grp_sess)

// Grupo: Exportación
grp_export = "Exportación MCP"
include_htf    = input.bool(true, "Incluir datos Higher Timeframe", group=grp_export)
include_levels = input.bool(true, "Incluir niveles clave", group=grp_export)
debug_table    = input.bool(false, "Mostrar tabla debug (visual)", group=grp_export, tooltip="Desactivar en producción para mejor rendimiento")

// ============================================================================
// CÁLCULOS BASE
// ============================================================================
// --- Volatilidad ---
atr14       = ta.atr(atr_len)
atr14_sma   = ta.sma(atr14, atr_sma_len)
atr_expand  = atr14 > atr14_sma
atr_expanding = atr_expand ? "true" : "false"

vol_sma     = ta.sma(volume, vol_len)
vol_rel     = vol_sma > 0 ? volume / vol_sma : 0.0

// --- Estructura de Precio ---
ema20  = ta.ema(close, ema20_len)
ema50  = ta.ema(close, ema50_len)
ema200 = ta.ema(close, ema200_len)

price_vs_ema20  = close > ema20  ? "above" : close < ema20  ? "below" : "at"
price_vs_ema50  = close > ema50  ? "above" : close < ema50  ? "below" : "at"
price_vs_ema200 = close > ema200 ? "above" : close < ema200 ? "below" : "at"

ema_align = if ema20 > ema50 and ema50 > ema200
    "bullish"
else if ema20 < ema50 and ema50 < ema200
    "bearish"
else
    "mixed"

// --- RSI + Divergencias ---
rsi14 = ta.rsi(close, rsi_len)

// Divergencia alcista: precio hace mínimo más bajo, RSI hace mínimo más alto
price_ll = low < ta.lowest(low, 5)[1]
rsi_hl   = rsi14 > ta.valuewhen(ta.lowest(low, 5) == low, rsi14, 1)
bull_div = price_ll and rsi_hl

// Divergencia bajista: precio hace máximo más alto, RSI hace máximo más bajo
price_hh = high > ta.highest(high, 5)[1]
rsi_lh   = rsi14 < ta.valuewhen(ta.highest(high, 5) == high, rsi14, 1)
bear_div = price_hh and rsi_lh

rsi_div = bull_div ? "bull_div" : bear_div ? "bear_div" : "none"

// --- Price Phase (Bollinger Width) ---
bb_basis = ta.sma(close, bb_len)
bb_dev   = ta.stdev(close, bb_len)
bb_upper = bb_basis + bb_mult * bb_dev
bb_lower = bb_basis - bb_mult * bb_dev
bb_width = (bb_upper - bb_lower) / bb_basis
bb_width_sma = ta.sma(bb_width, bb_len)

price_phase = bb_width < bb_width_sma * 0.8 ? "compression" :
              bb_width > bb_width_sma * 1.2 ? "expansion" : "transition"

// --- Sesiones (UTC) - Naming Convention alineado con agentes ---
hour_utc   = hour(time, "UTC")
minute_utc = minute(time, "UTC")
time_utc   = hour_utc * 100 + minute_utc

is_asia    = time_utc >= asia_start * 100   and time_utc < asia_end * 100
is_london  = time_utc >= london_start * 100 and time_utc < london_end * 100
is_ny      = time_utc >= ny_start * 100     and time_utc < ny_end * 100
is_overlap = is_london and is_ny  // 13:00-16:00 UTC por defecto

// Naming EXACTO como esperan los agentes (D001: consistencia temporal)
current_session = is_asia ? "Asian" : 
                  is_overlap ? "London-NY-Overlap" : 
                  is_london ? "London" : 
                  is_ny ? "NewYork" : "OffHours"

// Session extremes tracking
var float sess_high = na
var float sess_low  = na
var float prev_sess_high = na
var float prev_sess_low  = na
var string prev_session = na

session_changed = current_session != prev_session

if session_changed
    prev_sess_high := sess_high
    prev_sess_low  := sess_low
    sess_high      := high
    sess_low       := low
    prev_session   := current_session
else
    sess_high := math.max(nz(sess_high, high), high)
    sess_low  := math.min(nz(sess_low, low), low)

// Session break detection
sess_break = not na(prev_sess_high) and high > prev_sess_high ? "broke_high" :
             not na(prev_sess_low)  and low  < prev_sess_low  ? "broke_low" : "inside"

session_range = nz(sess_high, high) - nz(sess_low, low)

// --- Niveles Clave (Daily/Weekly) ---
prev_day_high  = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_on)
prev_day_low   = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_on)
day_open       = request.security(syminfo.tickerid, "D", open,     lookahead=barmerge.lookahead_on)
prev_week_high = request.security(syminfo.tickerid, "W", high[1],  lookahead=barmerge.lookahead_on)
prev_week_low  = request.security(syminfo.tickerid, "W", low[1],   lookahead=barmerge.lookahead_on)

// --- Higher Timeframe Context (solo si habilitado) ---
d1_ema_align = include_htf ? request.security(syminfo.tickerid, "D", ema_align, lookahead=barmerge.lookahead_on) : "na"
h4_ema_align = include_htf ? request.security(syminfo.tickerid, "240", ema_align, lookahead=barmerge.lookahead_on) : "na"
h1_phase     = include_htf ? request.security(syminfo.tickerid, "60", price_phase, lookahead=barmerge.lookahead_on) : "na"
m15_volatility = include_htf ? request.security(syminfo.tickerid, "15", atr14, lookahead=barmerge.lookahead_on) : na

// ============================================================================
// EXPORTACIÓN JSON PARA MCP (CRÍTICO)
// ============================================================================
// Este objeto JSON es consumido por los agentes vía price-feed MCP server
// Cualquier cambio aquí requiere actualizar schemas en agents/

json_payload = json.fromobject({
    // Metadata de trazabilidad (D006: Operating Modes)
    "aetheer_version": "1.2.0",
    "timestamp_utc": timenow,  // Epoch ms - agentes calculan age_hours
    "symbol": syminfo.ticker,
    "timeframe": timeframe.period,
    "bar_time": time,  // Epoch ms de la barra actual
    
    // Volatilidad / Liquidez
    "atr14": math.round(atr14, 5),
    "atr14_sma": math.round(atr14_sma, 5),
    "atr_expanding": atr_expand,
    "vol_rel": math.round(vol_rel, 2),
    "session_range": math.round(session_range, 5),
    
    // Estructura de Precio
    "ema20": math.round(ema20, 5),
    "ema50": math.round(ema50, 5),
    "ema200": math.round(ema200, 5),
    "price_vs_ema20": price_vs_ema20,
    "price_vs_ema50": price_vs_ema50,
    "price_vs_ema200": price_vs_ema200,
    "ema_align": ema_align,
    
    // RSI / Momentum
    "rsi14": math.round(rsi14, 2),
    "rsi_div": rsi_div,
    
    // Price Phase
    "price_phase": price_phase,
    "bb_width": math.round(bb_width, 4),
    "bb_width_percentile": na,  // Placeholder - calcular en agente con histórico
    
    // Sesiones
    "session": current_session,  // "Asian" | "London" | "NewYork" | "London-NY-Overlap"
    "sess_high": math.round(sess_high, 5),
    "sess_low": math.round(sess_low, 5),
    "prev_sess_high": math.round(prev_sess_high, 5),
    "prev_sess_low": math.round(prev_sess_low, 5),
    "sess_break": sess_break,  // "broke_high" | "broke_low" | "inside"
    
    // Niveles Clave (solo si habilitado)
    "prev_day_high": include_levels ? math.round(prev_day_high, 5) : null,
    "prev_day_low": include_levels ? math.round(prev_day_low, 5) : null,
    "day_open": include_levels ? math.round(day_open, 5) : null,
    "prev_week_high": include_levels ? math.round(prev_week_high, 5) : null,
    "prev_week_low": include_levels ? math.round(prev_week_low, 5) : null,
    
    // Contexto Multi-Timeframe (solo si habilitado)
    "htf_d1_ema_align": d1_ema_align,
    "htf_h4_ema_align": h4_ema_align,
    "htf_h1_phase": h1_phase,
    "htf_m15_atr14": include_htf ? math.round(m15_volatility, 5) : null,
    
    // Calidad de datos (para Operating Modes)
    "data_quality": "high",  // Placeholder - MCP server puede sobrescribir
    "source": "tradingview"  // Confirmado por MCP server
})

// Label oculto para exportación (MCP lee el texto del label)
// Usamos color transparente para no interferir visualmente
var label json_label = label.new(
     bar_index, 
     na, 
     json_payload, 
     style=label.style_none,
     color=color.new(color.black, 100), 
     textcolor=color.new(color.black, 100),
     xloc=xloc.bar_index
)
label.set_x(json_label, bar_index)
label.set_y(json_label, close)

// ============================================================================
// TABLA DEBUG (SOLO VISUAL - OPCIONAL)
// ============================================================================
if debug_table and barstate.islast
    var table debug_tbl = table.new(position.bottom_right, 2, 40, 
         bgcolor=color.new(color.black, 85), frame_color=color.gray, frame_width=1)
    
    row = 0
    // Header
    table.cell(debug_tbl, 0, row, "AETHEER v1.2", text_color=color.blue, text_size=size.small, colspan=2)
    row += 1
    
    // Volatilidad
    table.cell(debug_tbl, 0, row, "📊 VOLATILIDAD", text_color=color.yellow, text_size=size.tiny, colspan=2)
    row += 1
    table.cell(debug_tbl, 0, row, "ATR14", text_color=color.white, text_size=size.tiny)
    table.cell(debug_tbl, 1, row, str.tostring(math.round(atr14, 3), "#.###"), text_color=color.white, text_size=size.tiny)
    row += 1
    table.cell(debug_tbl, 0, row, "ATR_EXPANDING", text_color=color.white, text_size=size.tiny)
    table.cell(debug_tbl, 1, row, atr_expanding, text_color=atr_expand ? color.green : color.red, text_size=size.tiny)
    row += 1
    table.cell(debug_tbl, 0, row, "VOL_REL", text_color=color.white, text_size=size.tiny)
    table.cell(debug_tbl, 1, row, str.tostring(math.round(vol_rel, 2), "#.##"), text_color=color.white, text_size=size.tiny)
    row += 1
    
    // Estructura
    table.cell(debug_tbl, 0, row, "📐 ESTRUCTURA", text_color=color.yellow, text_size=size.tiny, colspan=2)
    row += 1
    table.cell(debug_tbl, 0, row, "EMA_ALIGN", text_color=color.white, text_size=size.tiny)
    align_color = ema_align == "bullish" ? color.green : ema_align == "bearish" ? color.red : color.orange
    table.cell(debug_tbl, 1, row, ema_align, text_color=align_color, text_size=size.tiny)
    row += 1
    table.cell(debug_tbl, 0, row, "PRICE_PHASE", text_color=color.white, text_size=size.tiny)
    phase_color = price_phase == "expansion" ? color.green : price_phase == "compression" ? color.orange : color.gray
    table.cell(debug_tbl, 1, row, price_phase, text_color=phase_color, text_size=size.tiny)
    row += 1
    table.cell(debug_tbl, 0, row, "RSI_DIV", text_color=color.white, text_size=size.tiny)
    div_color = rsi_div == "bull_div" ? color.green : rsi_div == "bear_div" ? color.red : color.gray
    table.cell(debug_tbl, 1, row, rsi_div, text_color=div_color, text_size=size.tiny)
    row += 1
    
    // Sesión
    table.cell(debug_tbl, 0, row, "🕐 SESIÓN", text_color=color.yellow, text_size=size.tiny, colspan=2)
    row += 1
    table.cell(debug_tbl, 0, row, "CURRENT", text_color=color.white, text_size=size.tiny)
    table.cell(debug_tbl, 1, row, current_session, text_color=color.blue, text_size=size.tiny)
    row += 1
    table.cell(debug_tbl, 0, row, "SESS_BREAK", text_color=color.white, text_size=size.tiny)
    break_color = sess_break == "broke_high" ? color.green : sess_break == "broke_low" ? color.red : color.gray
    table.cell(debug_tbl, 1, row, sess_break, text_color=break_color, text_size=size.tiny)
    row += 1
    
    // Niveles clave
    if include_levels
        table.cell(debug_tbl, 0, row, "🎯 NIVELES", text_color=color.yellow, text_size=size.tiny, colspan=2)
        row += 1
        table.cell(debug_tbl, 0, row, "PREV_DAY_HIGH", text_color=color.white, text_size=size.tiny)
        table.cell(debug_tbl, 1, row, str.tostring(prev_day_high, "#.#####"), text_color=color.white, text_size=size.tiny)
        row += 1
        table.cell(debug_tbl, 0, row, "PREV_DAY_LOW", text_color=color.white, text_size=size.tiny)
        table.cell(debug_tbl, 1, row, str.tostring(prev_day_low, "#.#####"), text_color=color.white, text_size=size.tiny)
        row += 1
    
    // Meta
    table.cell(debug_tbl, 0, row, "⚙️ META", text_color=color.gray, text_size=size.tiny, colspan=2)
    row += 1
    table.cell(debug_tbl, 0, row, "TF", text_color=color.gray, text_size=size.tiny)
    table.cell(debug_tbl, 1, row, timeframe.period, text_color=color.gray, text_size=size.tiny)
    row += 1
    table.cell(debug_tbl, 0, row, "DATA_QUALITY", text_color=color.gray, text_size=size.tiny)
    table.cell(debug_tbl, 1, row, "high", text_color=color.green, text_size=size.tiny)

// ============================================================================
// VALIDACIONES EN TIEMPO DE EJECUCIÓN (para debug)
// ============================================================================
// Alertas para detectar inconsistencias durante desarrollo
if debug_table
    // Validar que session naming coincide con agentes
    if current_session != "Asian" and current_session != "London" and current_session != "NewYork" and current_session != "London-NY-Overlap" and current_session != "OffHours"
        runtime.error("Session naming mismatch: " + current_session + " - debe coincidir con agentes")
    
    // Validar que ema_align tiene valores esperados
    if ema_align != "bullish" and ema_align != "bearish" and ema_align != "mixed"
        runtime.error("ema_align valor inválido: " + ema_align)