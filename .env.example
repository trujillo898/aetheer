# ============================================================================
# AETHEER v3.0 — variables de entorno
# Copia este archivo a `.env` y rellena los valores sensibles.
# ============================================================================

# --- LEGACY v1.2 (aún vivo mientras la migración avanza) -------------------
# FRED — datos macro (https://fred.stlouisfed.org/docs/api/api_key.html).
# Vacío = macro-data responde sin yields (degrada quality_score pero no fatal).
FRED_API_KEY=

# Alpha Vantage YA NO SE USA (D013). Se deja el nombre documentado para que
# nadie intente "reintroducirlo como fallback" — la decisión arquitectónica
# dice explícitamente que TradingView CDP es la única fuente de mercado.
# ALPHA_VANTAGE_API_KEY=deprecated_do_not_use

# --- OPENROUTER (Fase 1) ---------------------------------------------------
# Obten una key en https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Identificación opcional del app en los leaderboards de OpenRouter.
OPENROUTER_HTTP_REFERER=https://aetheer.local
OPENROUTER_APP_TITLE=Aetheer

# --- PRESUPUESTO DIARIO ---------------------------------------------------
# Límite hard en USD. Por encima, model_router rechaza llamadas premium.
AETHEER_DAILY_BUDGET_USD=10.00
# Alerta Telegram / log cuando gasto_diario >= pct * daily_cap.
AETHEER_BUDGET_ALERT_PCT=0.80
# Cuando gasto_diario >= soft_pct * daily_cap, forzar prefer_cheap en routing.
AETHEER_BUDGET_SOFT_PCT=0.50

# --- TRADINGVIEW CDP (D013 — fuente única) --------------------------------
TV_CDP_PORT=9222
TV_CACHE_DB=db/tv_cache.sqlite
# 1 = tv-health-monitor relanza TV Desktop si CDP cae.
AETHEER_AUTORESTART=0
# Comando de lanzamiento (adaptar a tu distro; Hyprland/Wayland en Ubuntu).
AETHEER_TV_LAUNCH_CMD=

# --- SYSTEM SERVICES (Fase 5) ---------------------------------------------
# Formato HH:MM en UTC. Comenta para desactivar el schedule.
# AETHEER_SCHEDULE_LONDON=07:00
# AETHEER_SCHEDULE_NY=12:30
# AETHEER_SCHEDULE_DAILY=22:00

# --- INTERFACES (Fase 6) ---------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_CHAT_IDS=
# WEBAPP_HOST=127.0.0.1
# WEBAPP_PORT=8080
# REDIS_URL=redis://localhost:6379/0

# --- OBSERVABILIDAD --------------------------------------------------------
AETHEER_LOG_LEVEL=INFO
# Path del SQLite donde CostMonitor persiste gasto diario.
AETHEER_COST_DB=db/aetheer_cost.sqlite
