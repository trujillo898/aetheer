{
  "mcpServers": {
    "tv-unified": {
      "command": "./.venv/bin/python",
      "args": ["mcp-servers/tv-unified/server.py"],
      "env": {
        "TV_CDP_PORT": "9222",
        "TV_CACHE_DB": "db/tv_cache.sqlite"
      }
    },
    "macro-data": {
      "command": "./.venv/bin/python",
      "args": ["mcp-servers/macro-data/server.py"],
      "env": {}
    },
    "memory": {
      "command": "./.venv/bin/python",
      "args": ["mcp-servers/memory/server.py"],
      "env": {
        "DB_PATH": "db/aetheer.db"
      }
    }
  }
}
